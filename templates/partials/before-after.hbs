<!-- Before/After side-by-side image panels -->
<div class="dpog-before-after flexrow">
    <!-- Before (original) panel -->
    <div class="dpog-image-panel">
        <h4 class="dpog-panel-label">{{i18n "DynPog.Before"}}</h4>
        <div class="dpog-image-container">
            <img id="dpog-before-img" src="" alt="{{i18n 'DynPog.BeforeAlt'}}" />
        </div>
        <span class="dpog-image-name" id="dpog-before-name">{{i18n "DynPog.NoImage"}}</span>
    </div>

    <!-- After (processed) panel -->
    <div class="dpog-image-panel">
        <h4 class="dpog-panel-label">{{i18n "DynPog.After"}}</h4>
        <div class="dpog-image-container">
            <img id="dpog-after-img" src="" alt="{{i18n 'DynPog.AfterAlt'}}" />
            <div class="dpog-ring-overlay" id="dpog-ring-overlay"></div>
        </div>
        <span class="dpog-image-name" id="dpog-after-name">{{i18n "DynPog.NoImage"}}</span>
        <button type="button" id="dpog-export-ring" class="dpog-export-ring-btn" disabled>
            <i class="fa-solid fa-circle"></i> {{i18n "DynPog.ExportRing"}}
        </button>
    </div>
</div>
