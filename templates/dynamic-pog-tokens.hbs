<!-- Dynamic Pog Tokens — main layout -->
<div class="dpog-app">
    <!-- Before/After image panels -->
    <div class="dpog-before-after flexrow">
        <!-- Before (original) panel -->
        <div class="dpog-image-panel">
            <h4 class="dpog-panel-label">{{localize "DynPog.Before"}}</h4>
            <div class="dpog-image-container">
                <img id="dpog-before-img" src="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 1 1%22/>" alt="{{localize 'DynPog.BeforeAlt'}}" />
            </div>
            <span class="dpog-image-name" id="dpog-before-name">{{localize "DynPog.NoImage"}}</span>
        </div>

        <!-- After (processed) panel -->
        <div class="dpog-image-panel">
            <h4 class="dpog-panel-label">{{localize "DynPog.After"}}</h4>
            <div class="dpog-image-container">
                <img id="dpog-after-img" src="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 1 1%22/>" alt="{{localize 'DynPog.AfterAlt'}}" />
            </div>
            <span class="dpog-image-name" id="dpog-after-name">{{localize "DynPog.NoImage"}}</span>
        </div>
    </div>

    <!-- Controls panel -->
    <div class="dpog-controls">
        <!-- Source selector -->
        <div class="dpog-control-row dpog-wide-row">
            <label class="dpog-control-label">{{localize "DynPog.Source"}}</label>
            <button type="button" id="dpog-select-images" class="dpog-select-btn">
                <i class="fa-solid fa-folder-open"></i> {{localize "DynPog.SelectFolder"}}
            </button>
            <span class="dpog-path-display" id="dpog-source-path"></span>
        </div>

        <!-- Destination folder -->
        <div class="dpog-control-row dpog-wide-row">
            <label class="dpog-control-label">{{localize "DynPog.Destination"}}</label>
            <button type="button" id="dpog-browse-dest" class="dpog-select-btn">
                <i class="fa-solid fa-folder"></i> {{localize "DynPog.Browse"}}
            </button>
            <span class="dpog-path-display" id="dpog-dest-path"></span>
        </div>

        <!-- Quality radio: Quick vs Optimized -->
        <div class="dpog-control-row">
            <label class="dpog-control-label">{{localize "DynPog.Quality"}}</label>
            <div class="dpog-radio-group">
                <label class="dpog-radio-label">
                    <input type="radio" name="quality" value="quick" />
                    <span>{{localize "DynPog.Quick"}}</span>
                </label>
                <label class="dpog-radio-label">
                    <input type="radio" name="quality" value="optimized" checked />
                    <span>{{localize "DynPog.Optimized"}}</span>
                </label>
            </div>
        </div>

        <div class="dpog-control-grid">
            <!-- Trim control -->
            <div class="dpog-control-row dpog-control-field">
                <label class="dpog-control-label" for="dpog-trim">{{localize "DynPog.Trim"}}</label>
                <input type="number" id="dpog-trim" name="trim" value="0" min="0" max="100" step="1" class="dpog-number-input" />
                <span class="dpog-unit">{{localize "DynPog.Pixels"}}</span>
            </div>

            <!-- Mask checkbox -->
            <div class="dpog-control-row dpog-control-field">
                <label class="dpog-control-label">{{localize "DynPog.Mask"}}</label>
                <label class="dpog-checkbox-label">
                    <input type="checkbox" id="dpog-mask" name="mask" />
                    <span>{{localize "DynPog.EnableMask"}}</span>
                </label>
            </div>
        </div>

        <!-- Mask threshold is required by mask processing, but intentionally hidden from the UI. -->
        <div class="dpog-control-row dpog-threshold-row dpog-hidden" aria-hidden="true">
            <label class="dpog-control-label" for="dpog-threshold">{{localize "DynPog.Threshold"}}</label>
            <input type="range" id="dpog-threshold" name="threshold" value="128" min="0" max="255" step="1" class="dpog-range-input" />
            <span class="dpog-range-value" id="dpog-threshold-value">128</span>
        </div>

        <!-- Ring size select -->
        <div class="dpog-control-row">
            <label class="dpog-control-label" for="dpog-ring-select">{{localize "DynPog.RingSize"}}</label>
            <select id="dpog-ring-select" name="ringSize" class="dpog-select">
                <option value="auto" selected>{{localize "DynPog.RingAuto"}}</option>
                <option value="tiny">{{localize "DynPog.RingTiny"}}</option>
                <option value="sm">{{localize "DynPog.RingSmallMedium"}}</option>
                <option value="lg">{{localize "DynPog.RingLarge"}}</option>
                <option value="huge">{{localize "DynPog.RingHuge"}}</option>
                <option value="grg">{{localize "DynPog.RingGargantuan"}}</option>
            </select>
        </div>

        <div class="dpog-control-grid">
            <!-- Output filename prefix -->
            <div class="dpog-control-row dpog-control-field">
                <label class="dpog-control-label" for="dpog-prefix">{{localize "DynPog.Prefix"}}</label>
                <input type="text" id="dpog-prefix" name="prefix" value="dynamic_ring_" class="dpog-text-input" />
            </div>

            <!-- Output filename suffix -->
            <div class="dpog-control-row dpog-control-field">
                <label class="dpog-control-label" for="dpog-suffix">{{localize "DynPog.Suffix"}}</label>
                <input type="text" id="dpog-suffix" name="suffix" value="" class="dpog-text-input" />
            </div>
        </div>

        <div class="dpog-control-grid">
            <!-- Export format radio -->
            <div class="dpog-control-row dpog-control-field">
                <label class="dpog-control-label">{{localize "DynPog.ExportFormat"}}</label>
                <div class="dpog-radio-group">
                    <label class="dpog-radio-label">
                        <input type="radio" name="exportFormat" value="webp" checked />
                        <span>{{localize "DynPog.Webp"}}</span>
                    </label>
                    <label class="dpog-radio-label">
                        <input type="radio" name="exportFormat" value="png" />
                        <span>{{localize "DynPog.Png"}}</span>
                    </label>
                </div>
            </div>

            <!-- Export ring checkbox -->
            <div class="dpog-control-row dpog-control-field">
                <label class="dpog-control-label">{{localize "DynPog.ExportRing"}}</label>
                <label class="dpog-checkbox-label">
                    <input type="checkbox" id="dpog-include-ring" name="includeRing" />
                    <span>{{localize "DynPog.IncludeRing"}}</span>
                </label>
            </div>
        </div>
    </div>

    <!-- Progress bar with percentage -->
    <div class="dpog-progress dpog-hidden" id="dpog-progress-section">
        <div class="dpog-progress-bar">
            <div class="dpog-progress-fill" id="dpog-progress-fill" style="width: 0%;"></div>
        </div>
        <span class="dpog-progress-text" id="dpog-progress-text">0%</span>
        <span class="dpog-progress-status" id="dpog-progress-status">{{localize "DynPog.Ready"}}</span>
    </div>

    <!-- Action button -->
    <div class="dpog-action-section">
        <button type="button" id="dpog-process-all" class="dpog-process-all-btn" disabled>
            <i class="fa-solid fa-play"></i> {{localize "DynPog.Process"}}
        </button>
    </div>
</div>
